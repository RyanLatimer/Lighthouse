<%= turbo_stream.replace "simulator_results" do %>
  <% if @red_score && @blue_score %>
    <div class="mt-6" id="simulator_results">
      <h2 class="text-lg font-bold text-white mb-4">Monte Carlo Simulation Results</h2>

      <%# Score Cards %>
      <div class="grid grid-cols-3 gap-4 mb-6">
        <div class="bg-gray-900 border border-red-500/30 rounded-xl p-4 text-center">
          <p class="text-xs text-red-400 uppercase tracking-wider mb-1">Red Alliance</p>
          <p class="text-4xl font-black text-red-400"><%= @red_score.round(1) %></p>
          <p class="text-xs text-gray-500 mt-1">avg predicted pts</p>
        </div>

        <div class="flex items-center justify-center">
          <span class="text-2xl font-black text-gray-600">VS</span>
        </div>

        <div class="bg-gray-900 border border-blue-500/30 rounded-xl p-4 text-center">
          <p class="text-xs text-blue-400 uppercase tracking-wider mb-1">Blue Alliance</p>
          <p class="text-4xl font-black text-blue-400"><%= @blue_score.round(1) %></p>
          <p class="text-xs text-gray-500 mt-1">avg predicted pts</p>
        </div>
      </div>

      <%# Win Probability (from Monte Carlo) %>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 mb-4">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-xs text-gray-500 uppercase tracking-wider">Win Probability</h3>
          <span class="text-xs text-gray-600"><%= @simulation[:red_win_pct] + @simulation[:blue_win_pct] < 100 ? "#{(100 - @simulation[:red_win_pct] - @simulation[:blue_win_pct]).round(1)}% tie" : "" %></span>
        </div>
        <div class="flex items-center gap-3 mb-2">
          <span class="text-sm font-bold text-red-400 w-16 text-right"><%= @red_win_pct %>%</span>
          <div class="flex-1 h-6 bg-gray-800 rounded-full overflow-hidden flex">
            <div class="h-full bg-gradient-to-r from-red-600 to-red-500 rounded-l-full transition-all" style="width: <%= @red_win_pct %>%"></div>
            <div class="h-full bg-gradient-to-r from-blue-500 to-blue-600 rounded-r-full transition-all" style="width: <%= @blue_win_pct %>%"></div>
          </div>
          <span class="text-sm font-bold text-blue-400 w-16"><%= @blue_win_pct %>%</span>
        </div>

        <% winner_color = @red_win_pct >= @blue_win_pct ? "red" : "blue" %>
        <div class="text-center mt-4 pt-4 border-t border-gray-800">
          <p class="text-xs text-gray-500">Predicted Margin of Victory</p>
          <p class="text-2xl font-bold text-<%= winner_color %>-400 mt-1"><%= @margin.round(1) %> pts</p>
          <p class="text-sm text-<%= winner_color %>-400/70"><%= winner_color.capitalize %> Alliance favored</p>
        </div>
      </div>

      <%# Simulation Details %>
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 mb-4">
        <h3 class="text-xs text-gray-500 uppercase tracking-wider mb-3">Simulation Details</h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          <div class="text-center">
            <p class="text-lg font-bold text-white"><%= @simulation[:red_win_pct] %>%</p>
            <p class="text-xs text-gray-500">Red Win Rate</p>
          </div>
          <div class="text-center">
            <p class="text-lg font-bold text-white"><%= @simulation[:blue_win_pct] %>%</p>
            <p class="text-xs text-gray-500">Blue Win Rate</p>
          </div>
          <div class="text-center">
            <p class="text-lg font-bold text-white"><%= @margin.round(1) %></p>
            <p class="text-xs text-gray-500">Avg Margin</p>
          </div>
          <div class="text-center">
            <p class="text-lg font-bold text-white"><%= (params[:iterations] || 1000).to_i %></p>
            <p class="text-xs text-gray-500">Iterations</p>
          </div>
        </div>
      </div>

      <%# Team Breakdown %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
          <h3 class="text-xs text-red-400 uppercase tracking-wider mb-3">Red Alliance Teams</h3>
          <div class="space-y-2">
            <% @red_summaries.includes(:frc_team).each do |summary| %>
              <div class="flex items-center justify-between bg-gray-800 rounded-lg px-3 py-2">
                <div>
                  <span class="font-bold text-red-400"><%= summary.frc_team.team_number %></span>
                  <span class="text-gray-500 text-xs ml-1"><%= summary.frc_team.nickname %></span>
                </div>
                <span class="font-mono text-sm text-white"><%= summary.avg_total_points.to_f.round(1) %> pts</span>
              </div>
            <% end %>
          </div>
        </div>

        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
          <h3 class="text-xs text-blue-400 uppercase tracking-wider mb-3">Blue Alliance Teams</h3>
          <div class="space-y-2">
            <% @blue_summaries.includes(:frc_team).each do |summary| %>
              <div class="flex items-center justify-between bg-gray-800 rounded-lg px-3 py-2">
                <div>
                  <span class="font-bold text-blue-400"><%= summary.frc_team.team_number %></span>
                  <span class="text-gray-500 text-xs ml-1"><%= summary.frc_team.nickname %></span>
                </div>
                <span class="font-mono text-sm text-white"><%= summary.avg_total_points.to_f.round(1) %> pts</span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
